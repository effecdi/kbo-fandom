# ============================================
# 서버 환경변수 (Railway Secrets에 설정)
# ============================================
#
# 환경별 설정:
#   - 프로덕션 (main 브랜치): 프로덕션 Supabase 프로젝트 값 사용
#   - 개발서버 (dev 브랜치): 개발 Supabase 프로젝트 값 사용
#   - 각 환경의 Railway 서비스에 해당 환경의 값을 설정하세요
#
# ============================================

# 필수: 데이터베이스 연결 (Supabase Postgres)
# - 프로덕션: 프로덕션 Supabase Connection String
# - 개발: 개발 Supabase Connection String
DATABASE_URL=postgresql://user:password@host:5432/database

# 필수: Supabase 설정
# - 프로덕션: 프로덕션 Supabase 프로젝트 URL/키
# - 개발: 개발 Supabase 프로젝트 URL/키
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key-here

# 필수: PortOne 결제 API (서버 전용)
PORTONE_API_KEY=your-portone-api-key
PORTONE_API_SECRET=your-portone-api-secret

# 선택: Gemini AI (이미지/텍스트 생성용)
AI_INTEGRATIONS_GEMINI_API_KEY=your-gemini-api-key
AI_INTEGRATIONS_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# 서버 포트 (Railway가 자동 설정하지만 기본값)
PORT=5000

# 환경 모드
NODE_ENV=production

# ============================================
# 클라이언트 환경변수 (Railway Variables에 설정)
# VITE_ 접두사가 붙은 값은 클라이언트 번들에 포함되므로 공개값만 사용!
# ============================================

# 필수: Supabase 클라이언트 설정 (공개값)
# - 프로덕션/개발 각각 해당 Supabase 프로젝트의 공개값 사용
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# 선택: PortOne 가맹점 ID (결제 UI용, 공개값)
VITE_PORTONE_MERCHANT_ID=imp00000000
